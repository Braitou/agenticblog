---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Agentic Flow. All rights reserved.
	<p class="footer-links">
		<a href="https://apps.shopify.com/agentic-flow-ai" target="_blank">Shopify App Store</a>
		&middot;
		<a href="/blog">Blog</a>
		&middot;
		<a href="/about">About</a>
	</p>
</footer>
<style>
	footer {
		padding: 2em 1em 4em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-links {
		margin-top: 0.5em;
		font-size: 0.85em;
	}
	.footer-links a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.footer-links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
